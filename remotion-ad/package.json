{
  "name": "cuentas-claras-remotion-ad",
  "version": "1.0.0",
  "description": "Publicidad dinámica de Cuentas Claras con Remotion",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render CuentasClarasAd out/ad.mp4 --codec=h264",
    "render": "remotion render CuentasClarasAd out/ad.mp4 --codec=h264",
    "still": "remotion still CuentasClarasAd --frame=0 out/still.png"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "remotion": "4.0.290",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "5.6.3"
  }
}
